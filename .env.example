# Runtime mode
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=debug
TZ=Asia/Shanghai

# Frontend
WEB_HOST=0.0.0.0
WEB_PORT=5173
VITE_APP_NAME=Agent Cluster
VITE_API_BASE_URL=http://localhost:3000/api
VITE_SSE_BASE_URL=http://localhost:3000/api
VITE_ENABLE_MOCKS=true

# Backend
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
SERVER_PUBLIC_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173
API_PREFIX=/api

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_cluster
POSTGRES_USER=agent_cluster
POSTGRES_PASSWORD=agent_cluster_dev
DATABASE_URL=postgresql://agent_cluster:agent_cluster_dev@localhost:5432/agent_cluster
DATABASE_SSL=false
DATABASE_LOGGING=true

# Redis and BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
BULLMQ_PREFIX=agent-cluster
QUEUE_CONCURRENCY=4

# LLM runtime defaults
LLM_PROVIDER=mock
LLM_MODEL=mock-fast
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_MS=60000
LLM_MAX_RETRIES=2
LLM_DRY_RUN=true

# Mock runtime
MOCK_RUNTIME_ENABLED=true
MOCK_RUNTIME_LATENCY_MS=300
MOCK_RUNTIME_FAILURE_RATE=0

# RAG and embeddings
RAG_ENABLED=true
RAG_MOCK_EMBEDDINGS=true
RAG_EMBEDDING_PROVIDER=mock
RAG_EMBEDDING_MODEL=mock-embedding
RAG_TOP_K=6
RAG_MIN_SCORE=0.5
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120

# Memory and token budget
MEMORY_ENABLED=true
TOKEN_BUDGET_DEFAULT=100000
TOKEN_ACCOUNTING_MODE=estimated

# Runtime and connector placeholders
CODEX_RUNTIME_ENABLED=false
CLAUDE_CODE_RUNTIME_ENABLED=false
MCP_RUNTIME_ENABLED=false
FEISHU_MOCK_ENABLED=true
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=

# Local development safety
ENABLE_HIGH_RISK_TOOLS=false
REQUIRE_USER_CONFIRMATION=true
ALLOW_FILE_WRITE_RUNTIME=false
ALLOW_COMMAND_RUNTIME=false
