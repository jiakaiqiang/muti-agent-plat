# Runtime mode
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=debug
TZ=Asia/Shanghai

# Frontend
WEB_HOST=0.0.0.0
WEB_PORT=5173
VITE_APP_NAME=Agent Cluster
VITE_API_BASE_URL=http://127.0.0.1:3000/api
VITE_SSE_BASE_URL=http://127.0.0.1:3000/api

# Backend
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
SERVER_PUBLIC_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
API_PREFIX=/api
AGENT_CLUSTER_PERSISTENCE=true
AGENT_CLUSTER_DATA_DIR=.cache/agent-cluster

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_cluster
POSTGRES_USER=agent_cluster
POSTGRES_PASSWORD=agent_cluster_dev
DATABASE_URL=postgresql://agent_cluster:agent_cluster_dev@localhost:5432/agent_cluster
DATABASE_SSL=false
DATABASE_LOGGING=true

# Redis and BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
BULLMQ_PREFIX=agent-cluster
QUEUE_CONCURRENCY=4

# LLM runtime (real-data mode: local Ollama, no mock fallback)
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_TIMEOUT_MS=180000
LLM_MAX_RETRIES=2
LLM_DRY_RUN=false
LLM_MOCK_FALLBACK=false

# Model management (connection credentials are encrypted at rest with AES-256-GCM)
# Master key for encrypting connection API keys. If unset, a local key is generated in the data
# dir (dev only) — set a stable value in production.
MODEL_CREDENTIAL_KEY=

# Mock runtime (disabled in real-data mode; set to true only for local mock/testing)
MOCK_RUNTIME_ENABLED=false
MOCK_RUNTIME_LATENCY_MS=300
MOCK_RUNTIME_FAILURE_RATE=0

# RAG and embeddings
RAG_ENABLED=true
RAG_MOCK_EMBEDDINGS=false
RAG_EMBEDDING_PROVIDER=local
RAG_EMBEDDING_MODEL=local-keyword-search
RAG_TOP_K=6
RAG_MIN_SCORE=0.5
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120

# Memory and token budget
MEMORY_ENABLED=true
TOKEN_BUDGET_DEFAULT=100000
TOKEN_ACCOUNTING_MODE=estimated

# Runtime and connector placeholders
CODEX_RUNTIME_ENABLED=false
CODEX_CLI_COMMAND=codex
CODEX_CLI_ARGS=
CLAUDE_CODE_RUNTIME_ENABLED=false
CLAUDE_CODE_CLI_COMMAND=claude
CLAUDE_CODE_CLI_ARGS=
MCP_RUNTIME_ENABLED=false
FEISHU_MOCK_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=
# Set true (plus a FEISHU_WEBHOOK_URL) to let the notification agent really send to Feishu after
# the user confirms; otherwise the post-delivery confirmation is a no-op (blocked) and only drafts.
ALLOW_FEISHU_SEND=false

# Local development safety
# 让 LLM 看到 file_write 工具(从而真正提出"改文件"的请求)需要把下面这条改成 true。
# 文件并不会因此被直接落盘——后端会拦下来,生成 code_diff 预览产物,并暂停到 WAIT_USER_DECISION
# 等用户在确认卡上点"写入文件"才真正写入会话运行环境目录。完整链路与开关说明:
#   1. ENABLE_HIGH_RISK_TOOLS=true        # 允许 file_write/command_run 这类高危能力被注入到 system prompt
#   2. AGENT_CLUSTER_SEED_DEFAULT_AGENTS=true  # 让默认的 backend agent 出现(它默认持有 cap-file-write)
#   3. 创建会话时选择一个本地目录作为"会话运行环境";这不是上传,只是告诉 runtime 在哪个根目录内工作
#   4. 用户在确认卡点"写入文件",此时确认本身视为对 cap-file-write 的授权,
#      因此 ALLOW_FILE_WRITE_RUNTIME 可以保持 false——只有需要无人值守落盘时才打开。
ENABLE_HIGH_RISK_TOOLS=false
REQUIRE_USER_CONFIRMATION=true
ALLOW_FILE_WRITE_RUNTIME=false
ALLOW_COMMAND_RUNTIME=false

# 让 /api/agents 默认带回 8 个内置 agent (coordinator/requirements/architect/frontend/backend/test/
# review/notification)。不打开时 agent 列表为空,没人持有 cap-file-write,LLM 也就拿不到 file_write 工具。
AGENT_CLUSTER_SEED_DEFAULT_AGENTS=true

# Controlled runtime execution (codex / claude_code adapters and tool executor)
# Real tool execution requires ENABLE_HIGH_RISK_TOOLS=true plus the matching ALLOW_* flag.
# File writes: set ENABLE_HIGH_RISK_TOOLS=true so agents may *propose* file writes. Proposed writes
# are not written directly — the orchestrator pauses (WAIT_USER_DECISION) and the user confirms each
# batch in the UI; an approved write is then applied to the session's workspace directory (the user's
# confirmation stands in for ALLOW_FILE_WRITE_RUNTIME for that write).
# AGENT_WORKSPACE_ROOT is the default/fallback workspace root. Each session may instead pick its own
# local runtime environment directory at creation time; this only records a local path and does not upload files.
AGENT_WORKSPACE_ROOT=
RUNTIME_TIMEOUT_MS=180000
RUNTIME_MAX_RETRIES=2
RUNTIME_TEST_COMMAND=npm test
