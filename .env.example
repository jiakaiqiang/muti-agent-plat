# Runtime mode
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=debug
TZ=Asia/Shanghai

# Frontend
WEB_HOST=0.0.0.0
WEB_PORT=5173
VITE_APP_NAME=Agent Cluster
VITE_API_BASE_URL=http://127.0.0.1:3000/api
VITE_SSE_BASE_URL=http://127.0.0.1:3000/api
VITE_ENABLE_MOCKS=false

# Backend
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
SERVER_PUBLIC_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173
API_PREFIX=/api
AGENT_CLUSTER_PERSISTENCE=true
AGENT_CLUSTER_PERSISTENCE_BACKEND=postgres
AGENT_CLUSTER_DATA_DIR=.cache/agent-cluster
AGENT_CLUSTER_DATA_FILE=
AGENT_CLUSTER_SEED_DEFAULT_AGENTS=false
AGENT_CLUSTER_RECOVER_ON_BOOT=true

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_cluster
POSTGRES_USER=agent_cluster
POSTGRES_PASSWORD=agent_cluster_dev
DATABASE_URL=postgresql://agent_cluster:agent_cluster_dev@localhost:5432/agent_cluster
DATABASE_SSL=false
DATABASE_LOGGING=true
AGENT_CLUSTER_POSTGRES_COLLECTION_TABLE=agent_cluster_collections

# Redis and BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
ENABLE_BULLMQ=true
BULLMQ_PREFIX=agent-cluster
REDIS_CONNECT_TIMEOUT_MS=5000
QUEUE_ATTEMPTS=3
QUEUE_CONCURRENCY=4

# LLM runtime defaults
DEFAULT_AGENT_RUNTIME_TYPE=generic_llm
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_MODEL_OPTIONS=llama3.2,qwen2.5,mistral,deepseek-r1
LLM_API_KEY=
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_TIMEOUT_MS=60000
LLM_MAX_RETRIES=2
LLM_DRY_RUN=false
LLM_MOCK_FALLBACK=false

# OpenAI-compatible cloud example:
# LLM_PROVIDER=openai-compatible
# LLM_MODEL=gpt-4.1-mini
# LLM_MODEL_OPTIONS=gpt-4.1-mini,gpt-4.1,gpt-4o-mini,gpt-4o
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1

# Mock runtime
MOCK_RUNTIME_ENABLED=false
MOCK_RUNTIME_DELAY_MS=300
MOCK_RUNTIME_FAILURE_RATE=0

# Multi-agent discussion
DISCUSSION_AGENT_KEYS=requirements,architect,backend,test
DISCUSSION_MAX_ROUNDS=1
DISCUSSION_TIMEOUT_MS=30000

# Explicit local mock mode for demos/tests:
# VITE_ENABLE_MOCKS=true
# DEFAULT_AGENT_RUNTIME_TYPE=mock
# LLM_MOCK_FALLBACK=true
# MOCK_RUNTIME_ENABLED=true

# RAG and embeddings
RAG_ENABLED=true
RAG_MOCK_EMBEDDINGS=false
RAG_EMBEDDING_PROVIDER=local
RAG_EMBEDDING_MODEL=local-keyword-search
RAG_TOP_K=6
RAG_MIN_SCORE=0.5
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120

# Memory and token budget
MEMORY_ENABLED=true
TOKEN_BUDGET_DEFAULT=100000
TOKEN_ACCOUNTING_MODE=estimated

# Runtime and connector placeholders
CODEX_RUNTIME_ENABLED=false
CLAUDE_CODE_RUNTIME_ENABLED=false
MCP_RUNTIME_ENABLED=false
FEISHU_MOCK_ENABLED=true
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=

# Local development safety
ENABLE_HIGH_RISK_TOOLS=false
REQUIRE_USER_CONFIRMATION=true
ALLOW_FILE_WRITE_RUNTIME=false
ALLOW_COMMAND_RUNTIME=false
